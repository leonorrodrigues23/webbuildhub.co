    color: #68727C;
    font-weight: 500;
  }
  .review-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    max-width: 190px;
    padding: 0.75rem 1.25rem;
    background: linear-gradient(135deg, #22C55E 0%, #16A34A 100%);
    color: white;
    font-weight: 700;
    font-size: 0.9375rem;
    text-decoration: none;
    border-radius: 8px;
    transition: all 0.2s ease;
  }
  .review-cta:hover {
    box-shadow: 0 4px 12px rgba(34, 197, 94, 0.3);
  }
  .review-cta:hover .arrow {
    transform: translateX(3px);
  }
  .review-cta-subtext {
    font-size: 0.8125rem;
    color: #68727C;
    text-align: center;
  }
  .review-right {
    flex: 1;
    position: relative;
    padding: 1.5rem 2rem;
  }
  .review-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .review-name {
    font-family: 'Sora', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #162433;
    margin: 0;
  }
  .review-rank {
    position: absolute;
    top: 0;
    right: 0;
    background: #1a365d;
    color: white;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
  }
  .review-best-for {
    display: inline-block;
    background: #EBF5FF;
    color: #1a365d;
    font-size: 0.8125rem;
    font-weight: 600;
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
    border: 1.5px solid #BFDBFE;
    margin-bottom: 1.25rem;
  }
  .spec-boxes {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 0;
    margin-bottom: 1.25rem;
    background: #F1F3F4;
    border-radius: 8px;
    padding: 1rem 1.25rem;
  }
  .spec-box {
    padding: 0.5rem 0.75rem;
    border-right: 1px solid #E2E8F0;
  }
  .spec-box:last-child {
    border-right: none;
  }
  @media (max-width: 640px) {
    .spec-boxes {
      grid-template-columns: repeat(2, 1fr);
    }
    .spec-box {
      border-right: none;
      border-bottom: 1px solid #E2E8F0;
    }
    .spec-box:nth-last-child(-n+2) {
      border-bottom: none;
    }
  }
  .spec-label {
    display: block;
    font-size: 0.6875rem;
    color: #68727C;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }
  .spec-value {
    font-size: 0.9375rem;
    font-weight: 700;
    color: #162433;
  }
  .review-description {
    font-size: 0.9375rem;
    color: #4B5563;
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  /* Pros & Cons Accordion */
  .pros-cons-accordion {
    border: 1px solid #E2E8F0;
    border-radius: 10px;
    overflow: hidden;
  }
  .accordion-trigger {
    width: 100%;
    padding: 1rem 1.25rem;
    background: #FFFFFF;
    font-weight: 700;
    color: #162433;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .accordion-trigger::-webkit-details-marker {
    display: none;
  }
  .accordion-trigger::after {
    content: '+';
    font-size: 1.25rem;
    font-weight: 400;
  }
  details[open] .accordion-trigger::after {
    content: '−';
  }
  .accordion-content {
    padding: 1.25rem;
    background: white;
  }
  .pros-section,
  .cons-section {
    margin-bottom: 1rem;
  }
  .cons-section {
    margin-bottom: 0;
  }
  .pros-title {
    font-size: 0.875rem;
    font-weight: 700;
    color: #16A34A;
    margin-bottom: 0.75rem;
  }
  .cons-title {
    font-size: 0.875rem;
    font-weight: 700;
    color: #DC2626;
    margin-bottom: 0.75rem;
  }
  .pros-list,
  .cons-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .pros-list li,
  .cons-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: #4B5563;
    line-height: 1.5;
    margin-bottom: 0.5rem;
  }
  .check {
    color: #16A34A;
    font-weight: 700;
    flex-shrink: 0;
  }
  .x {
    color: #DC2626;
    font-weight: 700;
    flex-shrink: 0;
  }

  /* ─────────────────────────────────────────────────────────────── */
  /* COMPARISON TABLE                                                */
  /* ─────────────────────────────────────────────────────────────── */
  .comparison-section {
    margin-bottom: 3rem;
    scroll-margin-top: 140px;
    width: 100vw;
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    max-width: 1400px;
    padding: 0 1.5rem;
    box-sizing: border-box;
  }
  .table-wrapper {
    overflow-x: auto;
    border: 1px solid #E2E8F0;
    border-radius: 12px;
    -webkit-overflow-scrolling: touch;
  }
  .comparison-table {
    width: 100%;
    min-width: 950px;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .comparison-table thead th {
    background: linear-gradient(135deg, #1a365d 0%, #2c5282 100%);
    color: white;
    padding: 1rem;
    text-align: left;
    font-weight: 600;
    white-space: nowrap;
  }
  .comparison-table thead th:first-child {
    border-radius: 12px 0 0 0;
  }
  .comparison-table thead th:last-child {
    border-radius: 0 12px 0 0;
  }
  .comparison-table tbody tr {
    border-bottom: 1px solid #E5E7EB;
  }
  .comparison-table tbody tr:last-child {
    border-bottom: none;
  }
  .comparison-table tbody td {
    padding: 1rem;
    vertical-align: middle;
  }
  .product-cell {
    min-width: 180px;
  }
  .table-editor-badge {
    display: inline-block;
    background: linear-gradient(135deg, #22C55E 0%, #16A34A 100%);
    color: white;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    margin-bottom: 0.5rem;
  }
  .product-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .table-image {
    width: 50px;
    height: 50px;
    object-fit: contain;
    border-radius: 8px;
    background: #FFFFFF;
  }
  .table-product-name {
    font-weight: 600;
    color: #162433;
  }
  .best-for-badge {
    display: inline-block;
    background: #EBF5FF;
    color: #1a365d;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
  }
  .spec-cell {
    font-weight: 600;
    color: #162433;
  }
  .rating-cell {
    font-weight: 700;
    color: #162433;
  }
  .table-cta {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: linear-gradient(135deg, #22C55E 0%, #16A34A 100%);
    color: white;
    font-weight: 600;
    font-size: 0.75rem;
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .table-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(34, 197, 94, 0.3);
  }
  .highlight-row {
    background: linear-gradient(90deg, #f0fdf4 0%, #fefefe 100%);
  }
  .ecommerce-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.625rem;
    border-radius: 4px;
    white-space: nowrap;
  }
  .ecommerce-full {
    background: #DCFCE7;
    color: #166534;
  }
  .ecommerce-limited {
    background: #F3F4F6;
    color: #6B7280;
  }
  .apps-cell {
    font-weight: 700;
    color: #162433;
  }

  /* ─────────────────────────────────────────────────────────────── */
  /* DECISION GUIDE                                                  */
  /* ─────────────────────────────────────────────────────────────── */
  .decision-guide {
    margin-bottom: 3rem;
    scroll-margin-top: 140px;
  }
  .guide-intro {
    font-size: 1rem;
    color: #4B5563;
    margin-bottom: 2.5rem;
    font-style: italic;
  }

  .guide-block {
    margin-bottom: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid #E5E7EB;
  }
  .guide-block:last-child { border-bottom: none; }
  .guide-block-title {
    font-family: 'Sora', sans-serif;
    font-size: 1.375rem;
    font-weight: 700;
    color: #162433;
    margin-bottom: 0.5rem;
  }
  .guide-block-subtitle {
    font-size: 0.9375rem;
    color: #68727C;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  /* STEP CARDS */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .step-card {
    background: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 12px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
  }
  .step-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .step-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    min-width: 28px;
    background: linear-gradient(135deg, #1a365d 0%, #2c5282 100%);
    color: white;
    font-family: 'Sora', sans-serif;
    font-size: 0.8125rem;
    font-weight: 700;
    border-radius: 8px;
  }
  .step-header h4 {
    font-family: 'Sora', sans-serif;
    font-size: 0.9375rem;
    font-weight: 700;
    color: #162433;
    margin: 0;
  }
  .step-list {
    list-style: none;
    padding: 0;
    margin: 0 0 auto;
  }
  .step-list li {
    font-size: 0.8125rem;
    color: #4B5563;
    line-height: 1.55;
    padding: 0.25rem 0 0.25rem 1rem;
    position: relative;
  }
  .step-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #94A3B8;
  }
  .step-time {
    margin-top: 0.75rem;
    padding-top: 0.625rem;
    border-top: 1px solid #F1F5F9;
    font-size: 0.75rem;
    font-weight: 600;
    color: #DC2626;
    font-family: 'Sora', sans-serif;
  }

  /* VERDICT / TIP BOXES */
  .guide-verdict-box {
    background: #F8FAFC;
    border: 1px solid #E2E8F0;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    font-size: 0.875rem;
    color: #162433;
    line-height: 1.6;
  }
  .guide-verdict-box strong { color: #1a365d; }
  .guide-tip-box {
    background: linear-gradient(135deg, #EFF6FF 0%, #F0FDF4 100%);
    border: 1px solid #BFDBFE;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    font-size: 0.875rem;
    color: #162433;
    line-height: 1.6;
  }
  .guide-tip-box strong { color: #1a365d; }

  /* COMPARE CARDS */
  .compare-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .compare-card {
    background: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 12px;
    padding: 1.25rem;
    position: relative;
  }
  .compare-card h4 {
    font-family: 'Sora', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: #162433;
    margin-bottom: 1rem;
  }
  .compare-winner {
    border: 2px solid #22C55E;
    background: linear-gradient(180deg, #F0FDF4 0%, #FFFFFF 40%);
  }
  .compare-card-label {
    display: inline-block;
    background: linear-gradient(135deg, #22C55E 0%, #16A34A 100%);
    color: white;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    margin-bottom: 0.5rem;
  }
  .compare-stats { display: flex; flex-direction: column; gap: 0; }
  .compare-stat {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.5rem 0;
    border-bottom: 1px solid #F1F5F9;
    gap: 0.5rem;
  }
  .compare-stat:last-child { border-bottom: none; }
  .compare-stat-label {
    font-size: 0.75rem;
    color: #68727C;
    white-space: nowrap;
  }
  .compare-stat-value {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #162433;
    text-align: right;
  }

  /* PRICING GROUPS */
  .pricing-group {
    background: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 12px;
    padding: 1.25rem;
    margin-bottom: 1rem;
  }
  .pricing-group-title {
    font-family: 'Sora', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: #162433;
    margin-bottom: 0.125rem;
  }
  .pricing-group-desc {
    font-size: 0.8125rem;
    color: #68727C;
    margin-bottom: 1rem;
  }
  .pricing-items { display: flex; flex-direction: column; gap: 0; }
  .pricing-item {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 0.5rem;
    border-bottom: 1px solid #F1F5F9;
    border-radius: 6px;
  }
  .pricing-item:last-child { border-bottom: none; }
  .pricing-item-highlight {
    background: linear-gradient(90deg, #F0FDF4 0%, #FFFFFF 100%);
    border: 1px solid #BBF7D0;
    border-bottom: 1px solid #BBF7D0;
    position: relative;
  }
  .pricing-name {
    font-size: 0.8125rem;
    font-weight: 700;
    color: #162433;
  }
  .pricing-detail {
    font-size: 0.8125rem;
    color: #68727C;
    line-height: 1.4;
  }
  .pricing-price {
    font-family: 'Sora', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    color: #162433;
    white-space: nowrap;
    text-align: right;
  }
  .pricing-promo {
    grid-column: 2 / -1;
    font-size: 0.6875rem;
    font-weight: 600;
    color: #16A34A;
  }

  /* RECOMMENDATION CARDS */
  .rec-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .rec-card {
    background: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 12px;
    padding: 1.25rem;
    border-left: 4px solid #94A3B8;
  }
  .rec-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }
  .rec-card-use {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #68727C;
  }
  .rec-card-price {
    font-family: 'Sora', sans-serif;
    font-size: 0.8125rem;
    font-weight: 700;
    color: #162433;
    background: #F1F5F9;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }
  .rec-card h4 {
    font-family: 'Sora', sans-serif;
    font-size: 1.0625rem;
    font-weight: 700;
    color: #162433;
    margin-bottom: 0.5rem;
  }
  .rec-card p {
    font-size: 0.8125rem;
    color: #4B5563;
    line-height: 1.55;
    margin-bottom: 0.5rem;
  }
  .rec-card-note {
    font-size: 0.75rem !important;
    color: #68727C !important;
    background: #F9FAFB;
    padding: 0.5rem 0.625rem;
    border-radius: 6px;
    margin-bottom: 0 !important;
  }
  .rec-shopify { border-left-color: #96BF48; }
  .rec-squarespace { border-left-color: #000000; }
  .rec-wordpress { border-left-color: #21759B; }
  .rec-wix { border-left-color: #FAAD4D; }
  .rec-weebly { border-left-color: #2C567E; }
  .rec-godaddy { border-left-color: #00A4A6; }

  /* CHECKLIST COLUMNS */
  .checklist-columns {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .checklist-group {
    background: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 12px;
    padding: 1.25rem;
  }
  .checklist-group-title {
    font-family: 'Sora', sans-serif;
    font-size: 0.9375rem;
    font-weight: 700;
    color: #162433;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #E5E7EB;
  }
  .checklist-item {
    display: flex;
    gap: 0.625rem;
    padding: 0.5rem 0;
    align-items: flex-start;
  }
  .checklist-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    min-width: 20px;
    background: #DCFCE7;
    color: #166534;
    font-size: 0.625rem;
    font-weight: 700;
    border-radius: 50%;
    margin-top: 1px;
  }
  .checklist-item strong {
    display: block;
    font-size: 0.8125rem;
    color: #162433;
    margin-bottom: 0.125rem;
  }
  .checklist-item span {
    font-size: 0.75rem;
    color: #68727C;
    line-height: 1.4;
  }

  /* MISTAKES GRID */
  .mistakes-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  .mistake-card {
    background: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 12px;
    padding: 1.25rem;
    position: relative;
  }
  .mistake-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
    color: #991B1B;
    font-family: 'Sora', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    border-radius: 6px;
    margin-bottom: 0.625rem;
  }
  .mistake-card h4 {
    font-family: 'Sora', sans-serif;
    font-size: 0.9375rem;
    font-weight: 700;
    color: #162433;
    margin-bottom: 0.5rem;
  }
  .mistake-card p {
    font-size: 0.8125rem;
    color: #4B5563;
    line-height: 1.55;
    margin-bottom: 0.625rem;
  }
  .mistake-fix {
    font-size: 0.75rem;
    color: #166534;
    background: #F0FDF4;
    padding: 0.5rem 0.625rem;
    border-radius: 6px;
    line-height: 1.5;
  }
  .mistake-fix strong { color: #166534; }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .steps-grid { grid-template-columns: 1fr; }
    .compare-cards { grid-template-columns: 1fr; }
    .rec-cards { grid-template-columns: 1fr; }
    .checklist-columns { grid-template-columns: 1fr; }
    .mistakes-grid { grid-template-columns: 1fr; }
    .pricing-item {
      grid-template-columns: 80px 1fr auto;
      gap: 0.5rem;
    }
  }

  /* ─────────────────────────────────────────────────────────────── */
  /* FAQ SECTION                                                     */
  /* ─────────────────────────────────────────────────────────────── */
  .faq-section {
    margin-bottom: 3rem;
    scroll-margin-top: 140px;
  }
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .faq-item {
    border: 1px solid #E2E8F0;
    border-radius: 10px;
    overflow: hidden;
  }
  .faq-question {
    width: 100%;
    padding: 1rem 1.25rem;
    background: #FFFFFF;
    font-weight: 600;
    color: #162433;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .faq-question::-webkit-details-marker {
    display: none;
  }
  .faq-question::after {
    content: '+';
    font-size: 1.25rem;
    font-weight: 400;
    color: #68727C;
  }
  details[open] .faq-question::after {
    content: '−';
  }
  .faq-answer {
    padding: 1.25rem;
    background: white;
  }
  .faq-answer p {
    font-size: 0.9375rem;
    color: #4B5563;
    line-height: 1.7;
    margin: 0;
  }

  /* ─────────────────────────────────────────────────────────────── */
  /* AUTHOR BIO                                                      */
  /* ─────────────────────────────────────────────────────────────── */
  .author-bio-section {
    display: flex;
    gap: 1.5rem;
    padding: 2rem;
    background: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 16px;
    margin-top: 3rem;
    scroll-margin-top: 140px;
  }
  @media (max-width: 640px) {
    .author-bio-section {

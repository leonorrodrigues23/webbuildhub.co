---
// ╔═══════════════════════════════════════════════════════════════╗
// ║  🧩 HEADER COMPONENT - Site navigation bar                    ║
// ║  Features CSS text logo fallback (Screened-style serif)       ║
// ╚═══════════════════════════════════════════════════════════════╝
import { SITE_BRAND } from '../consts';
---

<header class="site-header">
  <div class="header-container">
    <!-- 🖼️ Logo - Screened-style serif text -->
    <a href="/" class="logo-link" aria-label={`${SITE_BRAND} - Home`}>
      <div class="logo-container">
        <span class="logo-text">{SITE_BRAND}</span>
      </div>
    </a>

    <!-- 🔗 Navigation Links -->
    <nav class="main-nav">
      <a href="/#methodology" class="nav-link">How We Rank</a>
      <a href="/blog" class="nav-link">Blog</a>
      <a href="/about" class="nav-link">About Us</a>
      <a href="/contact" class="nav-link">Contact</a>
    </nav>

    <!-- 📱 Mobile Menu Button -->
    <button id="mobile-menu-btn" class="mobile-menu-btn" aria-label="Open mobile menu">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="menu-icon">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </div>

  <!-- 📱 Mobile Menu -->
  <div id="mobile-menu" class="mobile-menu hidden">
    <nav class="mobile-nav">
      <a href="/#methodology" class="mobile-nav-link">How We Rank</a>
      <a href="/blog" class="mobile-nav-link">Blog</a>
      <a href="/about" class="mobile-nav-link">About Us</a>
      <a href="/contact" class="mobile-nav-link">Contact</a>
    </nav>
  </div>
</header>

<style>
  /* Google Font for Screened-style logo */
  @import url('https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&display=swap');

  .site-header { 
    background: #ffffff; 
    border-bottom: 3px solid #E8EEF3; 
    position: sticky; 
    top: 0; 
    z-index: 50; 
  }
  
  .header-container { 
    max-width: 1200px; 
    margin: 0 auto; 
    padding: 1rem 2rem; 
    display: flex; 
    align-items: center; 
    justify-content: space-between; 
  }
  
  .logo-link { 
    display: flex; 
    align-items: center; 
    text-decoration: none;
  }
  
  .logo-image { 
    height: 40px; 
    width: auto; 
  }
  
  /* CSS Text Logo - Screened Style */
  .logo-container {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1;
  }

  .logo-text {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 1.625rem;
    font-weight: 700;
    color: #1E2E5C;
    letter-spacing: -0.5px;
    line-height: 1;
  }


  .main-nav { 
    display: flex; 
    align-items: center; 
    gap: 2.5rem; 
  }
  
  .nav-link { 
    font-family: 'Poppins', sans-serif; 
    font-size: 0.9375rem; 
    font-weight: 500; 
    color: #1a365d; 
    text-decoration: none; 
    transition: color 0.2s ease; 
  }
  
  .nav-link:hover { 
    color: #3182ce; 
  }
  
  .mobile-menu-btn { 
    display: none; 
    padding: 0.5rem; 
    background: transparent; 
    border: none; 
    cursor: pointer; 
    color: #1a365d; 
  }
  
  .menu-icon { 
    width: 24px; 
    height: 24px; 
  }
  
  .mobile-menu { 
    display: none; 
    background: #ffffff; 
    border-top: 1px solid #E8EEF3; 
    padding: 1rem 2rem; 
  }
  
  .mobile-menu.hidden { 
    display: none !important; 
  }
  
  .mobile-nav { 
    display: flex; 
    flex-direction: column; 
    gap: 1rem; 
  }
  
  .mobile-nav-link { 
    font-family: 'Poppins', sans-serif; 
    font-size: 1rem; 
    font-weight: 500; 
    color: #1a365d; 
    text-decoration: none; 
    padding: 0.5rem 0; 
  }
  
  @media (max-width: 768px) {
    .header-container { 
      padding: 0.875rem 1.25rem; 
    }
    .main-nav { 
      display: none; 
    }
    .mobile-menu-btn { 
      display: block; 
    }
    .mobile-menu:not(.hidden) { 
      display: block; 
    }
    .logo-text {
      font-size: 1.375rem;
    }
  }
</style>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  menuBtn?.addEventListener('click', () => mobileMenu?.classList.toggle('hidden'));
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => mobileMenu?.classList.add('hidden'));
  });
</script>

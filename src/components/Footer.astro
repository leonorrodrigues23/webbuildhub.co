---
// ╔═══════════════════════════════════════════════════════════════╗
// ║  🧩 FOOTER COMPONENT - Site footer with links                 ║
// ╚═══════════════════════════════════════════════════════════════╝
import { SITE_BRAND } from '../consts';
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-container">
    <div class="footer-grid">
      
      <!-- Column 1: About -->
      <div class="footer-column">
        <h4 class="footer-heading">About {SITE_BRAND}</h4>
        <ul class="footer-links">
          <li><a href="/about" class="footer-link">About Us</a></li>
          <li><a href="/contact" class="footer-link">Contact</a></li>
        </ul>
      </div>

      <!-- Column 2: Legal -->
      <div class="footer-column">
        <h4 class="footer-heading">Information</h4>
        <ul class="footer-links">
          <li><a href="/terms" class="footer-link">Terms of Use</a></li>
          <li><a href="/privacy" class="footer-link">Privacy Policy</a></li>
          <li><a href="/disclaimer" class="footer-link">Disclaimer</a></li>
          <li><a href="/disclaimer#affiliate" class="footer-link">Affiliate Disclosure</a></li>
        </ul>
      </div>

      <!-- Column 3: How It Works -->
      <div class="footer-column footer-column-wide">
        <h4 class="footer-heading">How We Work</h4>
        <p class="footer-description">
          We are a free resource for consumers. We may earn a commission from partners, but our reviews are based on data and customer insight, never paid placement.
        </p>
      </div>

    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="footer-bottom">
    <div class="footer-bottom-container">
      <a href="/" class="footer-logo-link">
        <span class="footer-logo-text">{SITE_BRAND}</span>
      </a>
      <p class="footer-copyright">© {currentYear} {SITE_BRAND}</p>
    </div>
  </div>
</footer>

<style>
  /* Google Font for Screened-style logo */
  @import url('https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&display=swap');

  .site-footer { background: #F5F8FA; margin-top: auto; }
  .footer-container { max-width: 1200px; margin: 0 auto; padding: 3.5rem 2rem 2.5rem; }
  .footer-grid { display: grid; grid-template-columns: 1fr 1fr 2fr; gap: 2.5rem; }
  .footer-column-wide { max-width: 380px; }
  .footer-heading { font-family: 'Sora', sans-serif; font-size: 1.125rem; font-weight: 700; color: #1a365d; margin-bottom: 1.25rem; padding-bottom: 0.75rem; border-bottom: 2px solid #1a365d; display: inline-block; }
  .footer-links { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.75rem; }
  .footer-link { font-family: 'Poppins', sans-serif; font-size: 0.9375rem; color: #4a5568; text-decoration: none; transition: color 0.2s ease; }
  .footer-link:hover { color: #1a365d; }
  .footer-description { font-family: 'Poppins', sans-serif; font-size: 0.9375rem; color: #4a5568; line-height: 1.7; }
  .footer-bottom { border-top: 1px solid #E2E8F0; background: #F5F8FA; }
  .footer-bottom-container { max-width: 1200px; margin: 0 auto; padding: 1.5rem 2rem; display: flex; align-items: center; justify-content: space-between; }
  .footer-logo-link { display: flex; align-items: center; text-decoration: none; }
  .footer-logo-text { font-family: 'Libre Baskerville', Georgia, serif; font-size: 1.375rem; font-weight: 700; color: #1E2E5C; letter-spacing: -0.5px; opacity: 0.8; transition: opacity 0.2s ease; }
  .footer-logo-link:hover .footer-logo-text { opacity: 1; }
  .footer-copyright { font-family: 'Poppins', sans-serif; font-size: 0.875rem; color: #718096; }
  @media (max-width: 1024px) {
    .footer-grid { grid-template-columns: repeat(2, 1fr); gap: 2rem; }
    .footer-column-wide { grid-column: span 2; max-width: 100%; }
  }
  @media (max-width: 640px) {
    .footer-container { padding: 2.5rem 1.25rem 2rem; }
    .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
    .footer-column-wide { grid-column: span 1; }
    .footer-bottom-container { flex-direction: column; gap: 1rem; text-align: center; padding: 1.25rem; }
  }
</style>
